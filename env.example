# Postgres (docker-compose)
POSTGRES_DB=planner
POSTGRES_USER=planner
POSTGRES_PASSWORD=planner
POSTGRES_PORT=5432

# Redis (docker-compose)
REDIS_PORT=6379

# API (FastAPI)
API_PORT=8000
APP_RUNTIME_PROFILE=dev
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://planner:planner@postgres:5432/planner
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000
STORAGE_ROOT=/data/uploads
STORAGE_BACKEND=local
# S3 backend (used when STORAGE_BACKEND=s3)
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT_URL=
AUTH_MODE=dev
AUTH_JWT_SECRET=change-me-for-production
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
TELEMETRY_ENABLED=false
TELEMETRY_SERVICE_NAME=academic-os-api
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# Worker: max parse/index attempts per background job before marking failed (default 3)
# WORKER_MAX_PARSE_ATTEMPTS=3

# Web (Next.js)
WEB_PORT=3000
# For browser/client-side calls:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# For server-side calls from inside the web container:
API_INTERNAL_BASE_URL=http://api:8000
API_AUTH_MODE=dev
NEXT_PUBLIC_API_AUTH_MODE=dev
# Optional: same UUID as a row in users — sends X-User-Id so dashboard + client match (see README).
# NEXT_PUBLIC_DEV_USER_ID=
# DEV_USER_ID=
# Optional bearer token mode (used when AUTH_MODE=bearer). Current spike expects token to be a user UUID.
# NEXT_PUBLIC_API_BEARER_TOKEN=
# API_BEARER_TOKEN=

# Production baseline:
# APP_RUNTIME_PROFILE=prod
# APP_ENV=production
# AUTH_MODE=bearer
# AUTH_JWT_SECRET=<at-least-32-char-random-secret>
# RATE_LIMIT_ENABLED=true

# AI (optional; Ask + Study Lab)
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# Embeddings: leave unset for keyword-only search/retrieval, or set:
# EMBEDDINGS_PROVIDER=openai
# OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
# For local embeddings (large deps: torch), use:
# EMBEDDINGS_PROVIDER=sentence-transformers
# SENTENCE_TRANSFORMERS_MODEL=sentence-transformers/all-MiniLM-L6-v2

